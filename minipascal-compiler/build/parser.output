Terminals unused in grammar

    TREAD


Grammar

    0 $accept: program $end

    1 program: TPROGRAM TIDENT TSEMI global_vars_opt functions_opt compound_stmt TDOT

    2 global_vars_opt: %empty
    3                | var_sections

    4 var_sections: TVAR var_decl_list
    5             | var_sections TVAR var_decl_list

    6 var_decl_list: ident_list TCOLON type_spec TSEMI
    7              | var_decl_list ident_list TCOLON type_spec TSEMI

    8 functions_opt: %empty
    9              | functions_opt function_decl
   10              | functions_opt procedure_decl

   11 function_decl: TFUNCTION TIDENT TLPAREN params_opt TRPAREN TCOLON type_spec TSEMI local_vars_opt compound_stmt TSEMI

   12 procedure_decl: TPROCEDURE TIDENT TLPAREN params_opt TRPAREN TSEMI local_vars_opt compound_stmt TSEMI

   13 local_vars_opt: %empty
   14               | var_sections

   15 params_opt: %empty
   16           | param_list

   17 param_list: TIDENT TCOLON type_spec
   18           | param_list TCOMMA TIDENT TCOLON type_spec

   19 type_spec: TINTEGER
   20          | TBOOLEAN

   21 compound_stmt: TBEGIN stmt_list_opt TEND

   22 stmt_list_opt: %empty
   23              | stmt_list

   24 stmt_list: statement
   25          | stmt_list TSEMI statement

   26 statement: assignment_stmt
   27          | if_stmt
   28          | while_stmt
   29          | for_stmt
   30          | return_stmt
   31          | write_stmt
   32          | expr_stmt
   33          | compound_stmt

   34 assignment_stmt: TIDENT TASSIGN expr

   35 if_stmt: TIF expr TTHEN statement
   36        | TIF expr TTHEN statement TELSE statement

   37 while_stmt: TWHILE expr TDO statement

   38 for_stmt: TFOR TIDENT TASSIGN expr TTO expr TDO statement

   39 return_stmt: TRETURN
   40            | TRETURN expr

   41 write_stmt: TWRITE TLPAREN write_args_opt TRPAREN
   42           | TWRITELN TLPAREN write_args_opt TRPAREN
   43           | TWRITELN

   44 expr_stmt: function_call

   45 write_args_opt: %empty
   46               | write_args

   47 write_args: expr
   48           | TSTRING
   49           | write_args TCOMMA expr
   50           | write_args TCOMMA TSTRING

   51 expr: expr TOR relation
   52     | expr TAND relation
   53     | relation

   54 relation: arith TEQ arith
   55         | arith TNE arith
   56         | arith TLT arith
   57         | arith TLE arith
   58         | arith TGT arith
   59         | arith TGE arith
   60         | arith

   61 arith: arith TPLUS term
   62      | arith TMINUS term
   63      | term

   64 term: term TMUL unary
   65     | term TDIV unary
   66     | term TMOD unary
   67     | unary

   68 unary: TMINUS unary
   69      | TPLUS unary
   70      | TNOT unary
   71      | factor

   72 factor: TINTLIT
   73       | TTRUE
   74       | TFALSE
   75       | TIDENT
   76       | function_call
   77       | TLPAREN expr TRPAREN

   78 function_call: TIDENT TLPAREN expr_list_opt TRPAREN

   79 expr_list_opt: %empty
   80              | expr_list

   81 expr_list: expr
   82          | expr_list TCOMMA expr

   83 ident_list: TIDENT
   84           | ident_list TCOMMA TIDENT


